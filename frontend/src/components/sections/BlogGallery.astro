---
// Cena 7: a galeria. Artigos como quadros iluminados por spots
// volumétricos numa sala escura. Montra, não arquivo.
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section id="gallery" class="gal">
    <h2 class="depth-title gal-title">Da galeria</h2>
    <div class="gal-room">
      {posts.map((post) => (
        <article class="gallery-frame">
          <a href={`/blog/${post.id}`} class="gal-link">
            <div class="gal-spot" aria-hidden="true"></div>
            <div class="gal-canvas">
              {post.data.image && (
                <img src={post.data.image} alt="" loading="lazy" class="gal-img" />
              )}
              <h3 class="gal-post-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="gal-desc">{post.data.description}</p>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
    <p class="gal-all">
      <a href="/blog">todo o arquivo →</a>
    </p>
  </section>
)}

<style>
  .gal {
    position: relative;
    z-index: 1;
    padding: 18vh clamp(1.25rem, 6vw, 5rem);
  }
  .gal-title {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    margin: 0 0 4rem;
    max-width: 68rem;
    margin-inline: auto;
  }
  .gal-room {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: 3rem;
    max-width: 68rem;
    margin: 0 auto;
  }

  .gallery-frame {
    position: relative;
  }
  .gal-link {
    display: block;
    text-decoration: none;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-frame:hover .gal-link {
    transform: rotate(-1deg) translateY(-4px);
  }
  .gal-spot {
    position: absolute;
    inset: -18% -10%;
    background: radial-gradient(ellipse at 50% 0%, rgba(232, 168, 85, 0.1), transparent 68%);
    opacity: 0.55;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .gallery-frame:hover .gal-spot {
    opacity: 1;
  }
  .gal-canvas {
    border: 1px solid rgba(232, 168, 85, 0.35);
    padding: 1rem;
    background: rgba(10, 14, 20, 0.65);
  }
  .gal-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    margin-bottom: 1rem;
    filter: saturate(0.85);
  }
  .gal-post-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--depth-white);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
  .gal-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--depth-white-dim);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gal-all {
    text-align: center;
    margin-top: 4rem;
  }
  .gal-all a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--depth-white-dim);
    text-decoration: none;
    border-bottom: 1px solid var(--depth-line);
    padding-bottom: 2px;
  }
  .gal-all a:hover {
    color: var(--depth-amber);
  }
</style>
