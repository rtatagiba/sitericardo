---
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-lg mb-3">Ricardo Tatagiba</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Consultor SEO Freelancer com mais de 10 anos de experiência em SEO e desenvolvimento full stack.
        </p>
      </div>

      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-3 text-gray-400">Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/sobre" class="text-gray-400 hover:text-accent transition-colors">Sobre</a></li>
          <li><a href="/servicos" class="text-gray-400 hover:text-accent transition-colors">Serviços</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/contato" class="text-gray-400 hover:text-accent transition-colors">Contato</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-3 text-gray-400">Contato</h3>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>
            <a href="mailto:contato@ricardotatagiba.com.br" class="hover:text-accent transition-colors">
              contato@ricardotatagiba.com.br
            </a>
          </li>
          <li>
            <a href="/politica-de-privacidade" class="hover:text-accent transition-colors">
              Política de Privacidade
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-10 pt-6 text-center text-gray-500 text-xs">
      &copy; {year} Ricardo Tatagiba. Todos os direitos reservados.
    </div>
  </div>
</footer>
