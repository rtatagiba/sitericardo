---
// Canvas Three.js persistente, atrás de todo o conteúdo.
// Inicializado em requestIdleCallback por scripts/main.js.
---

<canvas id="depth-canvas" aria-hidden="true"></canvas>

<style>
  #depth-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
