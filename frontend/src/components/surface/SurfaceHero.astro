---
// A simulação: uma página de resultados a sério — pesquisa feita,
// "melhor consultor de SEO", e todos os resultados são o próprio site.
// Igual a um motor de busca, sem nome nem logo de nenhum.
// Tudo [data-fragment] estilhaça no rasgo.
const query = 'melhor consultor de SEO';

const results = [
  {
    url: 'https://ricardotatagiba.com.br',
    crumb: 'ricardotatagiba.com.br',
    title: 'Ricardo Tatagiba — Consultor SEO Freelancer',
    desc: 'Consultor SEO Freelancer com mais de 10 anos de experiência. Ajudo empresas a crescer no Google com estratégias de SEO e marketing digital eficazes.',
  },
  {
    url: 'https://ricardotatagiba.com.br/servicos',
    crumb: 'ricardotatagiba.com.br › servicos',
    title: 'Serviços de SEO — Ricardo Tatagiba',
    desc: 'SEO técnico, SEO local, criação de conteúdo, Google Ads, Google My Business e automação com IA. Estratégias completas para a tua visibilidade online.',
  },
  {
    url: 'https://ricardotatagiba.com.br/ferramentas',
    crumb: 'ricardotatagiba.com.br › ferramentas',
    title: 'Ferramentas gratuitas de SEO e Marketing',
    desc: 'Ferramentas gratuitas para explorar perguntas reais, encontrar lacunas de conteúdo e melhorar o teu SEO — sem custos e sem registo.',
  },
  {
    url: 'https://ricardotatagiba.com.br/ferramentas/whattheyask',
    crumb: 'ricardotatagiba.com.br › ferramentas › whattheyask',
    title: 'What They Ask — O que as pessoas perguntam sobre qualquer tema',
    desc: 'Explora centenas de perguntas reais que as pessoas fazem sobre qualquer palavra-chave. Dados diretos do autocomplete, organizados por intenção.',
  },
  {
    url: 'https://ricardotatagiba.com.br/ferramentas/lacuna-de-conteudo',
    crumb: 'ricardotatagiba.com.br › ferramentas › lacuna-de-conteudo',
    title: 'Lacuna de Conteúdo — Os temas que os concorrentes cobrem e tu não',
    desc: 'Compara o teu site com os concorrentes e descobre os temas em falta no teu conteúdo. Análise gratuita de lacunas de conteúdo.',
  },
  {
    url: 'https://ricardotatagiba.com.br/blog',
    crumb: 'ricardotatagiba.com.br › blog',
    title: 'Blog de SEO e Marketing Digital — Ricardo Tatagiba',
    desc: 'Artigos práticos sobre SEO, Core Web Vitals, schema.org, SEO local e visibilidade em motores de busca e IAs. Conteúdo em português, sem enrolação.',
  },
  {
    url: 'https://ricardotatagiba.com.br/portfolio',
    crumb: 'ricardotatagiba.com.br › portfolio',
    title: 'Portfolio — Ricardo Tatagiba',
    desc: 'Casos reais de crescimento orgânico: mais tráfego, mais posições, mais clientes. Vê os resultados de quem já trabalhou comigo.',
  },
  {
    url: 'https://ricardotatagiba.com.br/sobre',
    crumb: 'ricardotatagiba.com.br › sobre',
    title: 'Sobre — Ricardo Tatagiba',
    desc: 'Mais de 10 anos entre SEO e desenvolvimento full stack. A história de quem otimiza sites por dentro e por fora.',
  },
  {
    url: 'https://ricardotatagiba.com.br/contato',
    crumb: 'ricardotatagiba.com.br › contato',
    title: 'Contato — Ricardo Tatagiba',
    desc: 'Vamos conversar sobre o teu negócio e como conseguir mais visibilidade orgânica. Resposta em menos de 24 horas.',
  },
