---
import BaseLayout from './BaseLayout.astro';
import { SITE_URL } from '../lib/seo/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  image?: string;
  tags?: string[];
  slug: string; // post.id in Astro v6
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { title, description, date, updatedDate, image, tags, slug, relatedPosts = [] } = Astro.props;

const postUrl = `${SITE_URL}/blog/${slug}/`;
const dateIso = date.toISOString();
const dateFormatted = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: title },
];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={title}
  canonical={postUrl}
  type="article"
  publishDate={date}
  updatedDate={updatedDate}
  tags={tags}
  breadcrumbs={breadcrumbs}
  markdownUrl={`${SITE_URL}/blog/${slug}.md`}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-neutral-400 mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="text-primary hover:text-accent transition-colors">Home</a></li>
        <li class="text-neutral-600">/</li>
        <li><a href="/blog" class="text-primary hover:text-accent transition-colors">Blog</a></li>
        <li class="text-neutral-600">/</li>
        <li class="text-neutral-400 font-medium truncate max-w-xs">{title}</li>
      </ol>
    </nav>

    <article>
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-primary leading-tight mb-4">
          {title}
        </h1>
        <time datetime={dateIso} class="text-neutral-400 text-sm">
          {dateFormatted}
        </time>
      </header>

      {image && (
        <img
          src={image}
          alt={title}
          class="w-full rounded-xl mb-10 object-cover max-h-96"
          loading="eager"
        />
      )}

      <div class="prose max-w-none">
        <slot />
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="mt-12 pt-8 border-t border-green-900" aria-labelledby="related-posts-heading">
        <h2 id="related-posts-heading" class="text-xl font-bold text-primary mb-6">
          Posts relacionados
        </h2>
        <ul class="flex flex-col gap-4">
          {relatedPosts.map((related) => (
            <li>
              <a
                href={`/blog/${related.id}/`}
                class="flex items-center gap-4 rounded-lg border border-green-900 p-3 hover:border-accent transition-colors"
              >
                {related.data.image && (
                  <img
                    src={related.data.image}
                    alt=""
                    class="w-24 h-24 shrink-0 rounded-md object-cover"
                    loading="lazy"
                  />
                )}
                <span class="min-w-0">
                  <span class="block font-medium text-primary mb-1">{related.data.title}</span>
                  <span class="block text-sm text-green-300 line-clamp-2">{related.data.description}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="mt-12 pt-8 border-t border-green-900">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-accent font-medium hover:text-accent-dark transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Voltar ao Blog
      </a>
    </div>
  </div>
</BaseLayout>
