---
import BaseLayout from './BaseLayout.astro';
import { SITE_URL } from '../lib/seo/site';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  image?: string;
  tags?: string[];
  slug: string; // post.id in Astro v6
}

const { title, description, date, updatedDate, image, tags, slug } = Astro.props;

const postUrl = `${SITE_URL}/blog/${slug}/`;
const dateIso = date.toISOString();
const dateFormatted = date.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: title },
];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={title}
  canonical={postUrl}
  type="article"
  publishDate={date}
  updatedDate={updatedDate}
  tags={tags}
  breadcrumbs={breadcrumbs}
  markdownUrl={`${SITE_URL}/blog/${slug}.md`}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-green-300 mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
        <li class="text-green-200">/</li>
        <li><a href="/blog" class="hover:text-accent transition-colors">Blog</a></li>
        <li class="text-green-200">/</li>
        <li class="text-primary font-medium truncate max-w-xs">{title}</li>
      </ol>
    </nav>

    <article>
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-primary leading-tight mb-4">
          {title}
        </h1>
        <time datetime={dateIso} class="text-green-300 text-sm">
          {dateFormatted}
        </time>
      </header>

      {image && (
        <img
          src={image}
          alt={title}
          class="w-full rounded-xl mb-10 object-cover max-h-96"
          loading="eager"
        />
      )}

      <div class="prose max-w-none">
        <slot />
      </div>
    </article>

    <div class="mt-12 pt-8 border-t border-green-900">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-accent font-medium hover:text-accent-dark transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Voltar ao Blog
      </a>
    </div>
  </div>
</BaseLayout>
