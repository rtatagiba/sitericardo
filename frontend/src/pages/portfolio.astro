---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Portfolio — Ricardo Tatagiba"
  description="Cases de sucesso e projetos de SEO e marketing digital desenvolvidos por Ricardo Tatagiba. Resultados reais para empresas brasileiras."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="text-4xl font-bold text-primary mb-4">Portfolio</h1>
    <p class="text-gray-600 text-lg mb-16 max-w-2xl">
      Projetos e cases de SEO que geraram resultados reais para meus clientes.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {[
        {
          sector: 'Hotelaria & Turismo',
          result: '+180% tráfego orgânico',
          desc: 'Estratégia de SEO local e conteúdo para hotel boutique. Crescimento de visibilidade em buscas locais e buscas por destino turístico.',
        },
        {
          sector: 'Pequenos Negócios',
          result: '+120% leads orgânicos',
          desc: 'Otimização completa de GMB + SEO local para empresa de serviços. Domínio das buscas na região de atuação.',
        },
        {
          sector: 'E-commerce',
          result: '+200% visibilidade',
          desc: 'Auditoria técnica, otimização de categoria e criação de conteúdo para loja virtual com mais de 500 produtos.',
        },
        {
          sector: 'Serviços Profissionais',
          result: 'Posição #1 no Google',
          desc: 'Estratégia de conteúdo + link building para consultório. Posição de destaque para palavras-chave de alta conversão.',
        },
      ].map(({ sector, result, desc }) => (
        <div class="border border-gray-100 rounded-xl p-8 hover:shadow-md transition-shadow">
          <div class="inline-block bg-accent/10 text-accent text-xs font-semibold px-3 py-1 rounded-full mb-4">
            {sector}
          </div>
          <div class="text-3xl font-bold text-primary mb-3">{result}</div>
          <p class="text-gray-600 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="text-gray-600 mb-6">Quer resultados como estes para o seu negócio?</p>
      <a
        href="/contato"
        class="inline-block bg-accent text-primary font-semibold px-10 py-3 rounded-lg hover:bg-accent-dark transition-colors"
      >
        Falar sobre o seu projeto
      </a>
    </div>
  </section>
</BaseLayout>
