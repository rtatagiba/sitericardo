---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getPublishedPosts } from '../../lib/seo/posts';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="Blog SEO — Ricardo Tatagiba"
  description="Artigos práticos sobre SEO, marketing digital, Google Ads e visibilidade online. Conteúdo para empresas brasileiras que querem crescer no Google."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-primary mb-4">Blog</h1>
    <p class="text-gray-600 text-lg mb-12 max-w-2xl">
      Conteúdo prático sobre SEO, marketing digital e estratégias para crescer no Google.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post: CollectionEntry<'blog'>) => (
        <article class="border border-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-shadow flex flex-col">
          {post.data.image && (
            <a href={`/blog/${post.id}`}>
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-48 object-cover hover:opacity-90 transition-opacity"
                loading="lazy"
              />
            </a>
          )}
          <div class="p-6 flex flex-col flex-1">
            <time class="text-xs text-gray-500 mb-2 block">
              {(post.data.date ?? post.data.pubDate ?? new Date(0)).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
            </time>
            <h2 class="font-bold text-lg mb-2 text-primary leading-snug flex-1">
              <a href={`/blog/${post.id}`} class="hover:text-accent transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 mb-4">
              {post.data.description}
            </p>
            <a
              href={`/blog/${post.id}`}
              class="text-accent text-sm font-medium hover:text-accent-dark transition-colors inline-flex items-center gap-1"
            >
              Ler artigo
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
