---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GapAnalyzer from "../../components/ContentGap/GapAnalyzer.astro";
---

<BaseLayout
  title="Lacuna de Conteúdo — Descobre os temas que os teus concorrentes cobrem e tu não"
  description="Ferramenta gratuita de content gap: compara o sitemap do teu site com o de um concorrente, identifica oportunidades de conteúdo e exporta tudo para Excel."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-primary mb-3">Lacuna de Conteúdo</h1>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">
        Compara o teu site com o de um concorrente através dos sitemaps e
        descobre todos os tópicos que ele já publicou — e tu ainda não.
      </p>
    </div>
    <GapAnalyzer />
  </section>
</BaseLayout>
