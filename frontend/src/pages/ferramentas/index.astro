---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tools = [
  {
    href: "/ferramentas/whattheyask",
    icon: "🔍",
    name: "WhatTheyAsk",
    description:
      "Descobre centenas de perguntas reais que as pessoas fazem sobre qualquer tema, com base no Google Suggest.",
  },
  {
    href: "/ferramentas/lacuna-de-conteudo",
    icon: "🧩",
    name: "Lacuna de Conteúdo",
    description:
      "Compara o teu site com o de um concorrente via sitemap e descobre os tópicos que eles cobrem e tu não. Exporta para Excel.",
  },
];
---

<BaseLayout
  title="Ferramentas gratuitas de SEO e Marketing"
  description="Ferramentas gratuitas para profissionais de SEO e Marketing: pesquisa de perguntas, análise de lacuna de conteúdo e mais."
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-primary mb-3">Ferramentas</h1>
      <p class="text-lg text-neutral-300 max-w-xl mx-auto">
        Ferramentas gratuitas para SEO e Marketing — sem registo, sem custos.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {tools.map(({ href, icon, name, description }) => (
        <a
          href={href}
          class="block bg-black rounded-xl border border-green-900 p-6 shadow-sm hover:shadow-md hover:border-accent/40 transition-all"
        >
          <p class="text-4xl mb-3">{icon}</p>
          <h2 class="text-xl font-semibold text-primary mb-2">{name}</h2>
          <p class="text-sm text-neutral-300 leading-relaxed">{description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
