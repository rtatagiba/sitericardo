---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = (await getCollection("blog"))
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.date.getTime() - a.data.date.getTime(),
  )
  .slice(0, 3);
---

<BaseLayout
  title="Ricardo Tatagiba — Consultor SEO Freelancer"
  description="Consultor SEO Freelancer com mais de 10 anos de experiência. Ajudo empresas brasileiras a crescer no Google com estratégias de SEO e marketing digital eficazes."
>
  <!-- Hero -->
  <section class="bg-primary text-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-8 flex items-end gap-4 min-h-[560px]">
      <!-- Foto esquerda -->
      <div class="relative flex-shrink-0 w-52 sm:w-64 lg:w-80 self-end select-none pointer-events-none">
        <img
          src="/images/Ricardo Tatagiba SEO Img Hero Matrix.webp"
          alt="Ricardo Tatagiba"
          class="w-full object-contain object-bottom"
          draggable="false"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-primary/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-primary to-transparent"></div>
      </div>

      <!-- Texto direita -->
      <div class="flex-1 py-24 text-right">
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
          Mais tráfego orgânico.<br />
          <span class="text-accent">Resultados reais.</span>
        </h1>
        <p class="text-lg text-gray-300 mb-10 leading-relaxed">
          Consultor SEO Freelancer com mais de 10 anos de experiência em SEO e
          desenvolvimento full stack. Ajudo empresas a conquistar posições no
          Google de forma sustentável.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-end">
          <a
            href="/contato"
            class="inline-block bg-accent text-primary font-semibold px-8 py-3 rounded-lg hover:bg-accent-dark transition-colors"
          >
            Falar comigo
          </a>
          <a
            href="/servicos"
            class="inline-block border border-gray-500 text-white font-semibold px-8 py-3 rounded-lg hover:border-accent hover:text-accent transition-colors"
          >
            Ver serviços
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Serviços -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4">O que eu faço</h2>
      <p class="text-gray-600 text-center mb-12 max-w-xl mx-auto">
        Estratégias completas para aumentar sua visibilidade online e atrair
        mais clientes.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          [
            {
              title: "SEO Técnico",
              desc: "Auditoria completa e otimização técnica para melhorar indexação e velocidade.",
            },
            {
              title: "SEO Local",
              desc: "Domínio do Google Maps e resultados locais para atrair clientes da sua região.",
            },
            {
              title: "Criação de Conteúdo",
              desc: "Conteúdo otimizado que educa, converte e ranqueia no Google.",
            },
            {
              title: "Google Ads",
              desc: "Campanhas pagas com foco em conversão e redução do custo por lead.",
            },
            {
              title: "Google My Business",
              desc: "Otimização do perfil GMB para dominar buscas locais.",
            },
            {
              title: "Automação com IA",
              desc: "Processos inteligentes para escalar resultados com menos esforço manual.",
            },
          ].map(({ title, desc }) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
              <h3 class="font-bold text-lg mb-2 text-primary">{title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
      <div class="text-center mt-10">
        <a
          href="/servicos"
          class="inline-block bg-primary text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition-colors"
        >
          Ver todos os serviços
        </a>
      </div>
    </div>
  </section>

  <!-- Blog recente -->
  {
    posts.length > 0 && (
      <section class="py-20 px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold mb-4">Artigos recentes</h2>
          <p class="text-gray-600 mb-12">
            Conteúdo prático sobre SEO, marketing digital e visibilidade online.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {posts.map((post: CollectionEntry<"blog">) => (
              <article class="border border-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-48 object-cover"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <time class="text-xs text-gray-500 mb-2 block">
                    {post.data.date.toLocaleDateString("pt-BR", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    })}
                  </time>
                  <h3 class="font-bold text-lg mb-2 text-primary leading-snug">
                    <a
                      href={`/blog/${post.id}`}
                      class="hover:text-accent transition-colors"
                    >
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-gray-600 text-sm leading-relaxed line-clamp-3">
                    {post.data.description}
                  </p>
                </div>
              </article>
            ))}
          </div>
          <div class="text-center mt-10">
            <a
              href="/blog"
              class="inline-block border border-primary text-primary font-semibold px-8 py-3 rounded-lg hover:bg-primary hover:text-white transition-colors"
            >
              Ver todos os artigos
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="bg-accent py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-primary mb-4">
        Pronto para crescer no Google?
      </h2>
      <p class="text-primary/80 mb-8 max-w-xl mx-auto">
        Vamos conversar sobre o seu negócio e como posso ajudá-lo a conseguir
        mais visibilidade orgânica.
      </p>
      <a
        href="/contato"
        class="inline-block bg-primary text-white font-semibold px-10 py-3 rounded-lg hover:bg-gray-800 transition-colors"
      >
        Entrar em contato
      </a>
    </div>
  </section>
</BaseLayout>
