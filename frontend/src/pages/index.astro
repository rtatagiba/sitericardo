---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = (await getCollection("blog"))
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      (b.data.date ?? b.data.pubDate ?? new Date(0)).getTime() - (a.data.date ?? a.data.pubDate ?? new Date(0)).getTime(),
  )
  .slice(0, 3);
---

<BaseLayout
  title="Ricardo Tatagiba — Consultor SEO Freelancer"
  description="Consultor SEO Freelancer com mais de 10 anos de experiência. Ajudo empresas brasileiras a crescer no Google com estratégias de SEO e marketing digital eficazes."
>
  <!-- Hero -->
  <Hero />

  <!-- Serviços -->
  <section class="py-20 px-4 bg-black">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4">O que eu faço</h2>
      <p class="text-neutral-300 text-center mb-12 max-w-xl mx-auto">
        Estratégias completas para aumentar sua visibilidade online e atrair
        mais clientes.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          [
            {
              title: "SEO Técnico",
              desc: "Auditoria completa e otimização técnica para melhorar indexação e velocidade.",
            },
            {
              title: "SEO Local",
              desc: "Domínio do Google Maps e resultados locais para atrair clientes da sua região.",
            },
            {
              title: "Criação de Conteúdo",
              desc: "Conteúdo otimizado que educa, converte e ranqueia no Google.",
            },
            {
              title: "Google Ads",
              desc: "Campanhas pagas com foco em conversão e redução do custo por lead.",
            },
            {
              title: "Google My Business",
              desc: "Otimização do perfil GMB para dominar buscas locais.",
            },
            {
              title: "Automação com IA",
              desc: "Processos inteligentes para escalar resultados com menos esforço manual.",
            },
          ].map(({ title, desc }) => (
            <div class="bg-black rounded-xl p-6 shadow-sm border border-green-900 hover:shadow-md transition-shadow">
              <h3 class="font-bold text-lg mb-2 text-primary">{title}</h3>
              <p class="text-neutral-300 text-sm leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
      <div class="text-center mt-10">
        <a
          href="/servicos"
          class="inline-block bg-black border border-green-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-neutral-900 transition-colors"
        >
          Ver todos os serviços
        </a>
      </div>
    </div>
  </section>

  <!-- Blog recente -->
  {
    posts.length > 0 && (
      <section class="py-20 px-4">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold mb-4">Artigos recentes</h2>
          <p class="text-neutral-300 mb-12">
            Conteúdo prático sobre SEO, marketing digital e visibilidade online.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {posts.map((post: CollectionEntry<"blog">) => (
              <article class="border border-green-900 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-48 object-cover"
                    loading="lazy"
                  />
                )}
                <div class="p-6">
                  <time class="text-xs text-neutral-400 mb-2 block">
                    {(post.data.date ?? post.data.pubDate ?? new Date(0)).toLocaleDateString("pt-BR", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    })}
                  </time>
                  <h3 class="font-bold text-lg mb-2 text-primary leading-snug">
                    <a
                      href={`/blog/${post.id}`}
                      class="hover:text-accent transition-colors"
                    >
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="text-neutral-300 text-sm leading-relaxed line-clamp-3">
                    {post.data.description}
                  </p>
                </div>
              </article>
            ))}
          </div>
          <div class="text-center mt-10">
            <a
              href="/blog"
              class="inline-block border border-primary text-primary font-semibold px-8 py-3 rounded-lg hover:bg-neutral-900 transition-colors"
            >
              Ver todos os artigos
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="bg-accent py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-black mb-4">
        Pronto para crescer no Google?
      </h2>
      <p class="text-black/80 mb-8 max-w-xl mx-auto">
        Vamos conversar sobre o seu negócio e como posso ajudá-lo a conseguir
        mais visibilidade orgânica.
      </p>
      <a
        href="/contato"
        class="inline-block bg-black text-white font-semibold px-10 py-3 rounded-lg hover:bg-neutral-900 transition-colors"
      >
        Entrar em contato
      </a>
    </div>
  </section>
</BaseLayout>
